Bootstrap: docker
From: python:3.13-slim

%files
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/
    src /app/src
    uv.lock /app/

%post
    # Install uv
    pip install uv

    # hatch-vcs needs a git repo to determine version; provide a fallback
    export SETUPTOOLS_SCM_PRETEND_VERSION=0.0.0

    # Sync the environment using uv (installs deps + local package)
    cd /app && uv sync --no-dev --no-editable

    # Make venv python available as 'python' (point directly to the real binary)
    ln -sf $(readlink -f /app/.venv/bin/python3) /usr/local/bin/python

%environment
    export PATH="/app/.venv/bin:$PATH"
    export VIRTUAL_ENV="/app/.venv"

    # Default data directories (can be overridden via --bind at runtime)
    export INPUT_DIR="data/raw"
    export OUTPUT_DIR="data/final"
